{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "crons": [
    { "path": "/api/internal/rotate-boards", "schedule": "0 13 * * 1" },
    { "path": "/api/internal/rotate-boards?mode=check", "schedule": "30 13 * * *" }
  ]
