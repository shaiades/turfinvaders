# Copy to .env.local and fill in values from the Supabase project
# (Settings → API). VITE_* vars are inlined into the browser bundle at
# build time; the rest are read by the server at runtime.

# Browser (public)
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon-or-publishable-key>"

# Server runtime (SSR, server functions, API routes)
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<anon-or-publishable-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key — secret, never expose to the browser>"

# Shared secret expected by /api/public/monday-webhook and
# /api/public/monday-live-dispatch (x-monday-secret header or ?secret=)
MONDAY_WEBHOOK_SECRET="<random-long-secret>"
